#!/usr/bin/env bash
# Pre-commit hook: blocks plain Kubernetes Secrets containing sensitive data.
#
# Blocks:
#   - kind: Secret with a `data:` block (base64-encoded secrets)
#   - kind: Secret with `stringData:` containing sensitive keys
#     (token, password, api-token, api-key, private-key, secret, credentials)
#
# Allows:
#   - kind: SealedSecret (safe to commit)
#   - kind: Secret used for non-sensitive config (e.g. ArgoCD repo registration
#     with only `url`, `type`, `enableOCI` etc.)
#
# Install once with: just install-hooks
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

STAGED_YAML=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.ya?ml$' || true)

if [ -z "$STAGED_YAML" ]; then
  exit 0
fi

ERRORS=0

for file in $STAGED_YAML; do
  [ -f "$file" ] || continue

  # Only inspect files that contain a plain Secret (not SealedSecret)
  if grep -qE '^kind: Secret$' "$file" && ! grep -qE '^kind: SealedSecret$' "$file"; then

    # Block if the secret has a `data:` block — base64-encoded values are always sensitive
    if grep -qE '^data:' "$file"; then
      echo -e "${RED}BLOCKED${NC} Secret with encoded data in: ${YELLOW}${file}${NC}"
      echo "        Seal it with kubeseal or remove the data: block."
      ERRORS=$((ERRORS + 1))
      continue
    fi

    # Block if stringData contains sensitive key names
    # Matches keys like: token, password, api-token, api-key, private-key, secret, credentials
    if grep -qE '^\s+(token|password|api[-_]token|api[-_]key|private[-_]key|secret|credentials)\s*:' "$file"; then
      echo -e "${RED}BLOCKED${NC} Secret with sensitive stringData key in: ${YELLOW}${file}${NC}"
      echo "        Seal it first:  just seal-<name>  (see: just --list)"
      ERRORS=$((ERRORS + 1))
      continue
    fi
  fi

  # Block *-sealed.yaml files that still contain the placeholder value
  if [[ "$file" == *-sealed.yaml ]]; then
    if grep -q 'REPLACE_WITH_SEALED_VALUE' "$file"; then
      echo -e "${RED}BLOCKED${NC} unsealed placeholder in: ${YELLOW}${file}${NC}"
      echo "        Replace the placeholder by running the appropriate seal-* recipe."
      ERRORS=$((ERRORS + 1))
    fi
  fi
done

if [ "$ERRORS" -ne 0 ]; then
  echo ""
  echo -e "${RED}Commit rejected:${NC} $ERRORS secret issue(s) found."
  echo "Run 'just --list' to see sealing commands."
  exit 1
fi
